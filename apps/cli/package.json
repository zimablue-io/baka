{
	"name": "baka",
	"version": "0.1.0",
	"license": "MIT",
	"private": true,
	"type": "module",
	"bin": {
		"baka": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"dev": "tsx src/index.ts",
		"baka": "tsx src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:real-llm": "RUN_REAL_LLM=1 vitest run test/baka-module-create.test.ts"
	},
	"dependencies": {
		"@baka/api": "workspace:*",
		"@inquirer/prompts": "^8.5.2",
		"@repo/agent-engine": "workspace:*",
		"@repo/ast-tooling": "workspace:*",
		"@repo/discovery-workflow": "workspace:*",
		"@repo/feature-planning-workflow": "workspace:*",
		"@repo/module-management-workflow": "workspace:*",
		"@repo/protocol": "workspace:*",
		"commander": "^15.0.0",
		"conf": "^15.1.0",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/node": "^22.19.15",
		"@vitest/coverage-v8": "4.1.8",
		"esbuild": "0.28.1",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.9.2",
		"vitest": "^4.1.8"
	}
}
