{
        "$schema": "https://json.schemastore.org/tsconfig",
        "compilerOptions": {
                "declaration": true,
                "declarationMap": true,
                "esModuleInterop": true,
                "incremental": false,
                "isolatedModules": true,
                "lib": ["es2022", "DOM", "DOM.Iterable"],
                "module": "NodeNext",
                "moduleDetection": "force",
                "moduleResolution": "NodeNext",
                "resolveJsonModule": true,
                "skipLibCheck": true,
                "strict": true,
                "target": "ES2022",
                "allowImportingTsExtensions": true,
                "noEmit": true,
                "baseUrl": ".",
                "paths": {
                        "@/*": ["./src/*"],
                        "@repo/protocol": ["../../packages/protocol/src/index.ts"],
                        "@repo/agent-engine": ["../../packages/agent-engine/src/index.ts"],
                        "@repo/ast-tooling": ["../../packages/ast-tooling/src/index.ts"]
                }
        }
}
