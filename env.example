# Baka engine LLM configuration. All variables are optional when the user
# has run `baka init` (in which case the user config is the source of truth);
# these env vars override the user config for the current process.
#
# BAKA_LLM_BASE_URL   - OpenAI-compatible endpoint (llama.cpp, Ollama, vLLM, LM Studio, OpenAI, ...)
# BAKA_LLM_API_KEY    - API key, or "none" for local servers
# BAKA_LLM_MODEL      - model id, e.g. gemma4:e4b
# BAKA_LLM_TEMPERATURE - default 0.0 (we want deterministic plans)
# BAKA_LLM_MAX_TOKENS - default 8192
# BAKA_LLM_TIMEOUT_MS - default 120000
# BAKA_USE_PI_ADAPTER - "1" to enable the optional pi-coding-agent adapter
BAKA_LLM_BASE_URL=http://localhost:8080
BAKA_LLM_API_KEY=llama.cpp
BAKA_LLM_MODEL=gemma4:e4b
BAKA_LLM_TEMPERATURE=0.0
BAKA_LLM_MAX_TOKENS=8192
BAKA_LLM_TIMEOUT_MS=120000
