# .envrc — project-level init for direnv.
# Runs whenever you `cd` into this directory (and any subdirectory).
#
# Order matters:
#   1. Source .env so BAKA_LLM_* vars are available
#   2. Ensure the baka CLI is built and symlinked (idempotent, fast on re-entry)
#   3. Add the project's bin dir to PATH so `baka` is a first-class command

if [ -f .env ]; then
	set -a
	source .env
	set +a
fi

# Run the setup script (idempotent). Skip if baka is already on PATH.
if ! command -v baka >/dev/null 2>&1; then
	# Don't trigger pnpm install from here (it would re-enter direnv).
	# We just ensure the bin is built; the install itself was done by the user.
	BAKA_SETUP_SKIP_INSTALL=1 ./scripts/setup.sh >/dev/null 2>&1 || true
fi

# Make the baka bin available in this direnv session.
export PATH="$PWD/node_modules/.bin:$PATH"
