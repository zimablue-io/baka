{
	"name": "baka",
	"private": true,
	"version": "0.1.0",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "biome check .",
		"test": "turbo run test",
		"check-types": "turbo run check-types",
		"pack": "rm -rf dist-tarballs && mkdir -p dist-tarballs && node scripts/pack.mjs baka --out \"$PWD/dist-tarballs\" && node scripts/pack.mjs @baka/mcp-server --out \"$PWD/dist-tarballs\"",
		"knip": "pnpm dlx knip@5",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"clean": "find . -name 'dist' -type d -exec rm -rf {} +",
		"setup": "./scripts/setup.sh",
		"postinstall": "pnpm --filter baka run build",
		"baka": "pnpm --filter baka baka",
		"mcp": "pnpm --filter @baka/mcp-server dev",
		"link:global": "pnpm --filter baka --filter @baka/mcp-server exec pnpm link --global"
	},
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/node": "^22.19.15",
		"turbo": "^2.9.18",
		"typescript": "5.9.2",
		"vitest": "^4.1.8"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=8.0.0"
	},
	"dependencies": {
		"workflow": "^4.4.0"
	}
}
